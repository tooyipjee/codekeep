{
  "name": "codekeep",
  "version": "0.9.6",
  "type": "module",
  "description": "CodeKeep: The Pale — deck-building tactical roguelike in your terminal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tooyipjee/codekeep.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "terminal",
    "game",
    "roguelike",
    "deck-building",
    "ascii",
    "cli",
    "tui"
  ],
  "bin": {
    "codekeep": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.tsx",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "chalk": "^5",
    "commander": "^13",
    "ink": "^6",
    "react": "^19"
  },
  "devDependencies": {
    "@codekeep/server": "workspace:*",
    "@codekeep/shared": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@vitest/coverage-v8": "3",
    "ink-testing-library": "^4",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
